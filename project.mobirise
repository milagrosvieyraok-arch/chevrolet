          "_name": "features04",
          "_sourceTheme": "energym5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features04 energym5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Date\" name=\"showDate\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#acb3b7\" name=\"border\" selected>\n        <input type=\"color\" title=\"Border Active Color\" value=\"#000000\" name=\"active\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"desc-wrapper\">\n                    <p class=\"mbr-desc mbr-fonts-style\" data-app-selector=\".mbr-desc\" mbr-theme-style=\"display-5\" mbr-if=\"showDesc\">\n                        Últimos modelos Chevrolet al servicio de tu empresa</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-3 item features-image item-mb\">\n                <a href=\"#\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"item-img\">\n                            <img src=\"@PROJECT_PATH@/assets/images/descarga-318x159.jpg\" alt=\"Chevrolet Van\">\n                        </div>\n                        <div class=\"item-content\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Chevrolet Tornado Van</h4>\n                            <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDate\" data-app-selector=\".card-date\">Ideal para entregas rápidas de material eléctrico/herramientas en zonas céntricas.\n                            </p>\n                        </div>\n                    </div>\n                </a>\n            </div>\n            <div class=\"col-12 col-lg-3 item features-image item-mb\">\n                <a href=\"#\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"item-img\">\n                            <img src=\"@PROJECT_PATH@/assets/images/descarga201-275x183.jpg\" alt=\"Chevrolet S10 Max\">\n                        </div>\n                        <div class=\"item-content\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Chevrolet S10 Max (Chasis/Doble Cabina)</h4>\n                            <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDate\" data-app-selector=\".card-date\">\n                                La combinación perfecta entre carga pesada y trabajo rudo.\n                            </p>\n                        </div>\n                    </div>\n                </a>\n            </div>\n            <div class=\"col-12 col-lg-3 item features-image item-mb\">\n                <a href=\"#\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"item-img\">\n                            <img src=\"@PROJECT_PATH@/assets/images/descarga202-318x159.jpg\" alt=\"Chevrolet Silverado\">\n                        </div>\n                        <div class=\"item-content\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">Chevrolet Silverado</h4>\n                            <p class=\"card-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDate\" data-app-selector=\".card-date\">\n                                Potencia máxima para arrastre y volumen industrial.\n                            </p>\n                        </div>\n                    </div>\n                </a>\n            </div>\n            \n        </div>\n    </div>\n</section>",
