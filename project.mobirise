          "_name": "footer01",
          "_sourceTheme": "energym5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer01 energym5\" group=\"Footer\" global once=\"footers\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#dfe6ea\" name=\"border\" condition=\"showBorder\" selected>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"range\" inline title=\"Amount\" name=\"nav\" min=\"0\" max=\"3\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Navigation Title\" name=\"showNavTitle\" checked>\n        <input type=\"color\" title=\"Active Color\" value=\"#000000\" name=\"active\" selected>\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopy\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12\">\n                <div class=\"border-wrap\" mbr-if=\"showBorder\"></div>\n            </div>\n            <div class=\"col-12 col-lg-6\" mbr-if=\"showText || showButtons\">\n                <div class=\"text-wrapper\">\n                    <div class=\"text-wrap\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrap, .mbr-section-btn\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                            Te acompañamos a mejorar el tiempo y rendimiento de tu Flota</p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-secondary\" href=\"index.html#contacto\" data-app-placeholder=\"Type Text\">Contactarme ahora</a></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-2\" mbr-if=\"nav > 0\">\n                <div class=\"nav-wrapper\">\n                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\">\n                        Menu\n                    </h4>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap, .contacts-wrapper\" data-multiline mbr-article>\n                        <li class=\"item-wrap\"><a href=\"index.html#top\" class=\"text-black\">Home</a></li>\n                        <li class=\"item-wrap\"><a href=\"index.html#flotilla\" class=\"text-black\">Flotilla</a></li>\n                        <li class=\"item-wrap\"><a href=\"index.html#pymes\" class=\"text-black\">Pymes</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-2\" mbr-if=\"nav > 1\">\n                <div class=\"nav-wrapper\">\n                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\">\n                        Social\n                    </h4>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap, .contacts-wrapper\" data-multiline mbr-article>\n                        <li class=\"item-wrap\"><a href=\"index.html\" class=\"text-black\">Instagram</a></li>\n                        <li class=\"item-wrap\"><a href=\"index.html\" class=\"text-black\">LinkedIn</a></li>\n                        <li class=\"item-wrap\"><a href=\"index.html\" class=\"text-black\">Twitter (X)</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-2\" mbr-if=\"nav > 2\">\n                <div class=\"nav-wrapper\">\n                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\">\n                        Contacts\n                    </h4>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap, .contacts-wrapper\" data-multiline mbr-article>\n                        <li class=\"item-wrap\">Phone</li>\n                        <li class=\"item-wrap\">Email</li>\n                        <li class=\"item-wrap\">Locations</li>\n                        <li class=\"item-wrap\">WhatsApp</li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"col-12\">\n                <p class=\"mbr-copy mbr-fonts-style\" data-app-selector=\".mbr-copy\" mbr-theme-style=\"display-4\" mbr-if=\"showCopy\">\n                    Todos los derechos reservados - CDMX Motors&nbsp; | Términos y condiciones</p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "tYpNQ4zUZw",
          "_anchor": "footer01-e",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    }
  }
}